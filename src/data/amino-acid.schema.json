{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Amino Acid Data",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string"
      },
      "code1": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1
      },
      "code3": {
        "type": "string",
        "minLength": 3,
        "maxLength": 3
      },
      "codons": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[ACGU]{3}$"
        }
      },
      "class": {
        "type": "string",
        "enum": [
          "Nonpolar",
          "Polar",
          "Acidic",
          "Basic"
        ]
      },
      "aaRS_class": {
        "type": "string",
        "enum": [
          "Class I",
          "Class II"
        ]
      },
      "tRNA_info": {
        "type": "string"
      },
      "atoms": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "element": {
              "type": "string"
            },
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            },
            "z": {
              "type": "number"
            },
            "label": {
              "type": "string"
            }
          },
          "required": [
            "element",
            "x",
            "y",
            "z"
          ]
        }
      },
      "bonds": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "from": { "type": "integer" },
            "to": { "type": "integer" },
            "order": { "type": "integer", "minimum": 1, "maximum": 3 }
          },
          "required": ["from", "to", "order"]
        }
      }
    },
    "required": [
      "name",
      "code1",
      "code3",
      "codons",
      "class",
      "aaRS_class",
      "tRNA_info",
      "atoms",
      "bonds"
    ]
  }
}
